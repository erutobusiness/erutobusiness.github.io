#!/bin/sh
# pre-push guard — this repo is GitHub Pages: push = live.
# Lists every file about to go public; pushes touching legal/top pages are
# blocked unless explicitly confirmed with PUSH_LIVE=1.

ZERO=0000000000000000000000000000000000000000
blocked=0

while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$ZERO" ] && continue # ブランチ削除は対象外

  if [ "$remote_sha" = "$ZERO" ]; then
    # 新規ブランチ: 全追跡ファイルが公開対象
    changed=$(git ls-tree -r --name-only "$local_sha")
  else
    changed=$(git diff --name-only "$remote_sha" "$local_sha")
  fi

  [ -z "$changed" ] && continue

  echo ""
  echo "=== push = 即公開です。公開される変更ファイル ==="
  echo "$changed" | sed 's/^/  /'
  echo "================================================"

  if echo "$changed" | grep -qE '^presentations/'; then
    echo "note: presentations/ changed — deploy built artifacts only (no manual edits)"
  fi

  if echo "$changed" | grep -qE '^(index\.html|legal\.html)$'; then
    if [ "$PUSH_LIVE" = "1" ]; then
      echo "PUSH_LIVE=1 が指定されたため index.html / legal.html の公開を許可"
    else
      echo ""
      echo "BLOCKED: index.html / legal.html（法的文書・トップページ）が含まれています"
      echo "内容を確認済みなら PUSH_LIVE=1 git push で実行してください"
      blocked=1
    fi
  fi
done

exit $blocked
